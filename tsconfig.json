{
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["next-auth.d.ts","next-env.d.ts", "**/*.ts", "src/pages/welcome.jsx", "src/pages/api/auth/custom-credentials.js", "src/pages/signup.tsx", "src/pages/api/auth/[...nextauth].ts", "src/pages/signup3.tsx", "src/pages/signup.tsx", "src/pages/api/slack.js"],
  "exclude": ["node_modules"]
}
